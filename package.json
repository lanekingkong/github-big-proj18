{
  "name": "uamp",
  "version": "1.0.0",
  "description": "Universal Agent Memory Sync Platform - Solve context fragmentation across AI tools",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/lanekingkong/UAMP.git"
  },
  "keywords": [
    "ai",
    "agent",
    "memory",
    "sync",
    "context",
    "claude-code",
    "cursor",
    "copilot",
    "multi-agent",
    "productivity"
  ],
  "author": "lanekingkong",
  "license": "MIT",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "lint": "eslint src --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx,js,jsx}'",
    "prepare": "husky install",
    "benchmark": "tsx benchmarks/index.ts",
    "perf:report": "tsx scripts/perf-report.ts",
    "package:win": "pkg dist/index.js -t node18-win-x64 -o dist/uamp.exe",
    "package:mac": "pkg dist/index.js -t node18-macos-x64 -o dist/uamp",
    "package:linux": "pkg dist/index.js -t node18-linux-x64 -o dist/uamp"
  },
  "dependencies": {
    "chromadb": "^1.8.0",
    "compression": "^1.7.4",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "js-yaml": "^4.1.0",
    "openai": "^4.28.0",
    "sqlite3": "^5.1.7",
    "uuid": "^9.0.0",
    "ws": "^8.16.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "husky": "^9.0.0",
    "prettier": "^3.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}